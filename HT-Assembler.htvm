include "HT-Lib.htvm"
; =========================================================================
; GLOBAL ASSEMBLER STATE
; =========================================================================
int use_custom_assembler_x86_64_linux := 0

arr str label_names
___cpp start
std::vector<int64_t> label_values;
___cpp end
uint64 current_address := 0
bool is_first_pass := false

func void add_label(str name, int64 addr) {
    label_names.add(name)
    label_values.add(addr)
}

func int64 get_label_address(str name) {
    Loop, label_names.size() {
        if (name = label_names[A_Index]) {
            return label_values[A_Index]
        }
    }
    return -1
}

func void set_current_address(uint64 addr) {
    current_address := addr
}

func uint64 get_current_address() {
    return current_address
}

func void set_first_pass(bool pass_state) {
    is_first_pass := pass_state
}

func int get_byte_count(str hex_str) {
    if (hex_str = "NULL" or hex_str = "") {
        return 0
    }
    int count := 0
    ; Using Parse instead of StrSplit ensures we never go out of bounds
    Loop, Parse, hex_str, " " {
        if (Trim(A_LoopField) != "") {
            count++
        }
    }
    return count
}



; Helper: convert string to boolean (InStr returns position, so >0 means true)
func bool is_mem(str op) {
    return (InStr(op, "[") > 0)
}

func bool is_imm(str op) {
    op := Trim(op)
    if (RegExMatch(op, "^-?[0-9]+$") > 0) { return true }
    if (RegExMatch(op, "^-?0x[0-9a-fA-F]+$") > 0) { return true }
    if (RegExMatch(op, "^'.*'$") > 0) { return true }
    return false
}

; Returns "id|size" e.g. "0|64" for rax, "1|32" for ecx, "15|8" for r15b
func str get_reg_info(str name) {
    arr str regs_64 := ["rax", "rcx", "rdx", "rbx", "rsp", "rbp", "rsi", "rdi", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15"]
    arr str regs_32 := ["eax", "ecx", "edx", "ebx", "esp", "ebp", "esi", "edi", "r8d", "r9d", "r10d", "r11d", "r12d", "r13d", "r14d", "r15d"]
    arr str regs_16 := ["ax", "cx", "dx", "bx", "sp", "bp", "si", "di", "r8w", "r9w", "r10w", "r11w", "r12w", "r13w", "r14w", "r15w"]
    arr str regs_8  := ["al", "cl", "dl", "bl", "spl", "bpl", "sil", "dil", "r8b", "r9b", "r10b", "r11b", "r12b", "r13b", "r14b", "r15b"]
    arr str regs_high := ["ah", "ch", "dh", "bh"]

    name := StrReplace(name, "qword ", "")
    name := StrReplace(name, "dword ", "")
    name := StrReplace(name, "word ", "")
    name := StrReplace(name, "byte ", "")
    name := StrReplace(name, "[", "")
    name := StrReplace(name, "]", "")
    name := Trim(name)

    Loop, regs_64.size() {
        if (name = regs_64[A_Index]) { return STR(A_Index) . "|64" }
    }
    Loop, regs_32.size() {
        if (name = regs_32[A_Index]) { return STR(A_Index) . "|32" }
    }
    Loop, regs_16.size() {
        if (name = regs_16[A_Index]) { return STR(A_Index) . "|16" }
    }
    Loop, regs_8.size() {
        if (name = regs_8[A_Index]) { return STR(A_Index) . "|8" }
    }
    Loop, regs_high.size() {
        if (name = regs_high[A_Index]) { return STR(A_Index + 4) . "|8" }
    }
    return "-1|0"
}

func int get_reg_id(str name, arr str registers) {

    name := StrReplace(name, "qword ", "")
    name := StrReplace(name, "dword ", "")
    name := StrReplace(name, "word ", "")
    name := StrReplace(name, "byte ", "")
    name := StrReplace(name, "[", "")
    name := StrReplace(name, "]", "")
    name := Trim(name)
    
    Loop, registers.size() {
        if (name = registers[A_Index]) {
            return A_Index
        }
    }
    return -1
}

; Helper to map mnemonics to opcodes
func int get_mnemonic_info(str name, str info_type) {
    if (name = "add") {
        if (info_type = "base_op") { return 0x00 }
        if (info_type = "imm_ext") { return 0 }
    } else if (name = "or") {
        if (info_type = "base_op") { return 0x08 }
        if (info_type = "imm_ext") { return 1 }
    } else if (name = "adc") {
        if (info_type = "base_op") { return 0x10 }
        if (info_type = "imm_ext") { return 2 }
    } else if (name = "sbb") {
        if (info_type = "base_op") { return 0x18 }
        if (info_type = "imm_ext") { return 3 }
    } else if (name = "and") {
        if (info_type = "base_op") { return 0x20 }
        if (info_type = "imm_ext") { return 4 }
    } else if (name = "sub") {
        if (info_type = "base_op") { return 0x28 }
        if (info_type = "imm_ext") { return 5 }
    } else if (name = "xor") {
        if (info_type = "base_op") { return 0x30 }
        if (info_type = "imm_ext") { return 6 }
    } else if (name = "cmp") {
        if (info_type = "base_op") { return 0x38 }
        if (info_type = "imm_ext") { return 7 }
    }
    return -1
}

func int get_jcc_code(str name) {
    if (name = "jo") { return 0 }
    if (name = "jno") { return 1 }
    if (name = "jb" or name = "jc" or name = "jnae") { return 2 }
    if (name = "jnb" or name = "jnc" or name = "jae") { return 3 }
    if (name = "je" or name = "jz") { return 4 }
    if (name = "jne" or name = "jnz") { return 5 }
    if (name = "jbe" or name = "jna") { return 6 }
    if (name = "jnbe" or name = "ja") { return 7 }
    if (name = "js") { return 8 }
    if (name = "jns") { return 9 }
    if (name = "jp" or name = "jpe") { return 10 }
    if (name = "jnp" or name = "jpo") { return 11 }
    if (name = "jl" or name = "jnge") { return 12 }
    if (name = "jnl" or name = "jge") { return 13 }
    if (name = "jle" or name = "jng") { return 14 }
    if (name = "jg" or name = "jnle") { return 15 }
    return -1
}



func str encode(str instruction) {
    bool dest_is_mem := false
    bool src_is_mem := false
    bool src_is_imm := false
    bool mem_is_imm := false
    bool force_rex := false
    int disp_size := 0
    int64 disp := 0
    uint64 REX := 0x40
    uint64 opcode := 0
    uint64 modrm := 0
    uint64 sib := 0
    int64 imm_val := 0
    str out_hex := ""
    str dest_op := ""
    str src_op := ""
    str str0 := ""
    bool has_0F := false

    instruction := Trim(instruction)
    arr str registers := ["rax", "rcx", "rdx", "rbx", "rsp", "rbp", "rsi", "rdi", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15"]

    if (instruction = "syscall") { return "0f 05" }
    if (instruction = "rep movsq") { return "f3 48 a5" }

    int space_pos := InStr(instruction, " ")
    str mnemonic := "mov"
    str ops_str := ""
    if (space_pos > 0) {
        mnemonic := Trim(SubStr(instruction, 1, space_pos))
        ops_str := Trim(SubStr(instruction, space_pos + 1))
    }

    int first_comma := InStr(ops_str, ",")
    if (first_comma > 0) {
        dest_op := Trim(SubStr(ops_str, 1, first_comma - 1))
        src_op  := Trim(SubStr(ops_str, first_comma + 1))
    } else {
        dest_op := Trim(ops_str)
        src_op  := ""
    }

    bool is_imul_3_op := false
    str imul_imm_str := ""
    if (mnemonic = "imul") {
        str op3 := Trim(StrSplit(ops_str, ",", 3))
        if (op3 != "") {
            is_imul_3_op := true
            dest_op := Trim(StrSplit(ops_str, ",", 1))
            src_op := Trim(StrSplit(ops_str, ",", 2))
            imul_imm_str := op3
        }
    }

    dest_is_mem := InStr(dest_op, "[")
    src_is_mem  := InStr(src_op, "[")
    src_is_imm  := is_imm(src_op)
    bool dest_is_imm := is_imm(dest_op)
    
    if (instruction = "ret") {
        if (dest_op = "") { return "c3" }
        int64 imm := parse_number(dest_op)
        return "c2 " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF)
    }
    if (mnemonic = "push" and dest_is_imm) {
        int64 imm := parse_number(dest_op)
        if (imm >= -128 and imm <= 127) { return "6a " . dec_to_hex_pair(imm & 0xFF) } 
        else if (imm >= -2147483648 and imm <= 2147483647) {
            return "68 " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF) . " " . dec_to_hex_pair((imm >> 16) & 0xFF) . " " . dec_to_hex_pair((imm >> 24) & 0xFF)
        }
        return "NULL" 
    }
    if (mnemonic = "int" and dest_is_imm) {
        int64 imm := parse_number(dest_op)
        return (imm = 3) ? "cc" : ("cd " . dec_to_hex_pair(imm & 0xFF))
    }

    if (dest_is_mem and src_is_mem) { return "NULL" }

    bool dest_has_high := (dest_op = "ah" or dest_op = "ch" or dest_op = "dh" or dest_op = "bh")
    bool src_has_high  := (src_op = "ah" or src_op = "ch" or src_op = "dh" or src_op = "bh")
    bool has_high_byte := (dest_has_high or src_has_high)

    bool is_direct_jump_or_call := false
    if (mnemonic = "call" or SubStr(mnemonic, 1, 1) = "j") {
        if (RegExMatch(dest_op, "^-?(0x)?[0-9a-fA-F]+$")) {
            is_direct_jump_or_call := true
        } else {
            int64 label_addr := get_label_address(dest_op)
            if (label_addr != -1 or is_first_pass) {
                is_direct_jump_or_call := true
            }
        }
    }

    if (SubStr(mnemonic, 1, 1) = "j" and mnemonic != "jmp") {
        if (is_direct_jump_or_call = false) { return "NULL" }
    }

    if (is_direct_jump_or_call) {
        int64 target := 0
        bool is_label := (RegExMatch(dest_op, "^-?(0x)?[0-9a-fA-F]+$") = 0)
        int64 label_addr := get_label_address(dest_op)
        
        if (label_addr != -1) {
            target := label_addr
        } else {
            if (is_label = false) {
                target := parse_number(dest_op)
            } else {
                if (is_first_pass) {
                    if (mnemonic = "call") { return "e8 00 00 00 00" }
                    else if (mnemonic = "jmp") { return "e9 00 00 00 00" }
                    else {
                        int cc := get_jcc_code(mnemonic)
                        return "0f " . dec_to_hex_pair(0x80 + cc) . " 00 00 00 00"
                    }
                } else {
                    return "NULL"
                }
            }
        }

        if (mnemonic = "call") {
            int64 offset := target - (4194304 + current_address + 5)
            out_hex := "e8"
            out_hex .= " " . dec_to_hex_pair(offset & 0xFF) . " " . dec_to_hex_pair((offset >> 8) & 0xFF) . " " . dec_to_hex_pair((offset >> 16) & 0xFF) . " " . dec_to_hex_pair((offset >> 24) & 0xFF)
            return out_hex
        }
        else if (mnemonic = "jmp") {
            if (is_label) {
                int64 offset32 := target - (4194304 + current_address + 5)
                out_hex := "e9"
                out_hex .= " " . dec_to_hex_pair(offset32 & 0xFF) . " " . dec_to_hex_pair((offset32 >> 8) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 16) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 24) & 0xFF)
                return out_hex
            } else {
                int64 offset8 := target - (4194304 + current_address + 2)
                if (offset8 >= -128 and offset8 <= 127) {
                    out_hex := "eb " . dec_to_hex_pair(offset8 & 0xFF)
                } else {
                    int64 offset32 := target - (4194304 + current_address + 5)
                    out_hex := "e9"
                    out_hex .= " " . dec_to_hex_pair(offset32 & 0xFF) . " " . dec_to_hex_pair((offset32 >> 8) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 16) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 24) & 0xFF)
                }
                return out_hex
            }
        }
        else {
            int cc := get_jcc_code(mnemonic)
            if (is_label) {
                int64 offset32 := target - (4194304 + current_address + 6)
                out_hex := "0f " . dec_to_hex_pair(0x80 + cc)
                out_hex .= " " . dec_to_hex_pair(offset32 & 0xFF) . " " . dec_to_hex_pair((offset32 >> 8) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 16) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 24) & 0xFF)
                return out_hex
            } else {
                int64 offset8 := target - (4194304 + current_address + 2)
                if (offset8 >= -128 and offset8 <= 127) {
                    out_hex := dec_to_hex_pair(0x70 + cc) . " " . dec_to_hex_pair(offset8 & 0xFF)
                } else {
                    int64 offset32 := target - (4194304 + current_address + 6)
                    out_hex := "0f " . dec_to_hex_pair(0x80 + cc)
                    out_hex .= " " . dec_to_hex_pair(offset32 & 0xFF) . " " . dec_to_hex_pair((offset32 >> 8) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 16) & 0xFF) . " " . dec_to_hex_pair((offset32 >> 24) & 0xFF)
                }
                return out_hex
            }
        }
    }
    
    int inst_len := 6
    str dest_info := get_reg_info(dest_op)
    int dest_reg_id := INT(StrSplit(dest_info, "|", 1))
    int dest_reg_sz := INT(StrSplit(dest_info, "|", 2))

    str src_info := get_reg_info(src_op)
    int src_reg_id := INT(StrSplit(src_info, "|", 1))
    int src_reg_sz := INT(StrSplit(src_info, "|", 2))

    int d_sz := 0
    int s_sz := 0
    if (dest_is_mem = false) { d_sz := dest_reg_sz }
    if (src_is_mem = false) { s_sz := src_reg_sz }

    int op_size := 64
    if (d_sz > 0) { op_size := d_sz }
    else if (s_sz > 0) { op_size := s_sz }
    else if (InStr(dest_op, "qword") or InStr(src_op, "qword")) { op_size := 64 }
    else if (InStr(dest_op, "dword") or InStr(src_op, "dword")) { op_size := 32 }
    else if (InStr(dest_op, "word") or InStr(src_op, "word")) { op_size := 16 }
    else if (InStr(dest_op, "byte") or InStr(src_op, "byte")) { op_size := 8 }

    if (mnemonic = "jmp" or mnemonic = "call" or mnemonic = "push" or mnemonic = "pop") {
    } else {
        if (op_size = 64) { REX += 0x08 } 
    }

    if (op_size = 16) { out_hex := "66 " }

    if (dest_is_mem = false and dest_reg_sz = 8 and dest_reg_id >= 4 and dest_reg_id <= 7 and dest_has_high = false) { force_rex := true }
    if (src_is_mem = false and src_is_imm = false and src_reg_sz = 8 and src_reg_id >= 4 and src_reg_id <= 7 and src_has_high = false) { force_rex := true }

    bool is_shift_rotate := (mnemonic = "shl" or mnemonic = "shr" or mnemonic = "sar" or mnemonic = "sal" or mnemonic = "rol" or mnemonic = "ror" or mnemonic = "rcl" or mnemonic = "rcr")
    int ext := 0
    if (is_shift_rotate) {
        if (mnemonic = "rol") { ext := 0 }
        else if (mnemonic = "ror") { ext := 1 }
        else if (mnemonic = "rcl") { ext := 2 }
        else if (mnemonic = "rcr") { ext := 3 }
        else if (mnemonic = "shl" or mnemonic = "sal") { ext := 4 }
        else if (mnemonic = "shr") { ext := 5 }
        else if (mnemonic = "sar") { ext := 7 }
    }

    if (dest_is_mem or src_is_mem) {
        str mem_str := ""
        int reg_id := 0
        int mem_size := 64
        
        if (dest_is_mem) {
            mem_str := dest_op
            if (InStr(mem_str, "byte")) { mem_size := 8 }
            else if (InStr(mem_str, "word")) { mem_size := 16 }
            else if (InStr(mem_str, "dword")) { mem_size := 32 }
            
            if (src_is_imm and is_shift_rotate = false) {
                mem_is_imm := true
                str trim_src := Trim(src_op)
                if (RegExMatch(trim_src, "^'.*'$") > 0) {
                    str char1 := StrReplace(trim_src, "'", "")
                    imm_val := Asc(Trim(char1))
                } else {
                    imm_val := parse_number(trim_src)
                }
                if (mnemonic = "mov") {
                    opcode := (op_size = 8) ? 0xC6 : 0xC7
                    reg_id := 0
                } else if (mnemonic = "test") {
                    opcode := (op_size = 8) ? 0xF6 : 0xF7
                    reg_id := 0
                } else {
                    if (op_size > 8 and imm_val >= -128 and imm_val <= 127) {
                        opcode := 0x83
                    } else {
                        opcode := (op_size = 8) ? 0x80 : 0x81
                    }
                    reg_id := get_mnemonic_info(mnemonic, "imm_ext")
                }
            } else if (is_shift_rotate) {
                if (src_op = "1") {
                    opcode := (op_size = 8) ? 0xD0 : 0xD1
                } else if (src_op = "cl") {
                    opcode := (op_size = 8) ? 0xD2 : 0xD3
                } else if (src_is_imm) {
                    opcode := (op_size = 8) ? 0xC0 : 0xC1
                    mem_is_imm := true
                    imm_val := parse_number(src_op)
                } else {
                    return "NULL"
                }
                reg_id := ext
            } else if (src_op = "") {
                if (mnemonic = "push" or mnemonic = "pop") {
                    if (op_size = 8 or op_size = 32) { return "NULL" }
                    if (mnemonic = "push") {
                        reg_id := 6
                        opcode := 0xFF
                    } else {
                        reg_id := 0
                        opcode := 0x8F
                    }
                } else {
                    int ext_single := 0
                    if (mnemonic = "inc") { ext_single := 0 }
                    else if (mnemonic = "dec") { ext_single := 1 }
                    else if (mnemonic = "call") { ext_single := 2 }
                    else if (mnemonic = "not") { ext_single := 2 }
                    else if (mnemonic = "neg") { ext_single := 3 }
                    else if (mnemonic = "jmp") { ext_single := 4 }
                    else if (mnemonic = "mul") { ext_single := 4 }
                    else if (mnemonic = "imul") { ext_single := 5 }
                    else if (mnemonic = "div") { ext_single := 6 }
                    else if (mnemonic = "idiv") { ext_single := 7 }
                    
                    reg_id := ext_single
                    bool is_group3 := (mnemonic = "not" or mnemonic = "neg" or mnemonic = "mul" or mnemonic = "imul" or mnemonic = "div" or mnemonic = "idiv")
                    if (mnemonic = "call" or mnemonic = "jmp") {
                        opcode := 0xFF
                    } else if (is_group3) {
                        opcode := (op_size = 8) ? 0xF6 : 0xF7
                    } else {
                        opcode := (op_size = 8) ? 0xFE : 0xFF
                    }
                }
            } else {
                reg_id := src_reg_id
                if (mnemonic = "mov") {
                    opcode := (op_size = 8) ? 0x88 : 0x89
                } else if (mnemonic = "test") {
                    opcode := (op_size = 8) ? 0x84 : 0x85
                } else {
                    int base_op := get_mnemonic_info(mnemonic, "base_op")
                    opcode := (op_size = 8) ? base_op : (base_op + 1)
                }
            }
        } else {
            mem_str := src_op
            if (InStr(mem_str, "byte")) { mem_size := 8 }
            else if (InStr(mem_str, "word")) { mem_size := 16 }
            else if (InStr(mem_str, "dword")) { mem_size := 32 }
            
            reg_id := dest_reg_id
            
            if (mnemonic = "mov") {
                opcode := (op_size = 8) ? 0x8A : 0x8B
            } else if (mnemonic = "movzx") {
                has_0F := true
                opcode := (mem_size = 8) ? 0xB6 : 0xB7
            } else if (mnemonic = "movsx") {
                has_0F := true
                opcode := (mem_size = 8) ? 0xBE : 0xBF
            } else if (mnemonic = "movsxd") {
                opcode := 0x63
            } else if (mnemonic = "test") {
                opcode := (op_size = 8) ? 0x84 : 0x85
            } else if (mnemonic = "lea") {
                if (op_size = 8) { return "NULL" }
                opcode := 0x8D
            } else if (is_imul_3_op) {
                if (op_size = 8) { return "NULL" }
                int64 imul_imm_temp := parse_number(imul_imm_str)
                bool imm_fits_8 := (imul_imm_temp >= -128 and imul_imm_temp <= 127)
                opcode := imm_fits_8 ? 0x6B : 0x69
            } else if (mnemonic = "imul") {
                if (op_size = 8) { return "NULL" }
                has_0F := true
                opcode := 0xAF
            } else {
                int base_op := get_mnemonic_info(mnemonic, "base_op")
                opcode := (op_size = 8) ? (base_op + 2) : (base_op + 3)
            }
        }

        str inner := StrSplit(mem_str, "[", 2)
        inner := StrReplace(inner, "]", "")
        
        bool is_pure_disp := false
        if (RegExMatch(inner, "^-?(0x)?[0-9a-fA-F]+$")) {
            is_pure_disp := true
            disp := parse_number(inner)
            disp_size := 4
            inner := ""
        }

        bool has_disp := false
        str val := ""
        str op := ""
        
        if (is_pure_disp = false) {
            str p3 := Trim(StrSplit(inner, " + ", 3))
            str p2 := Trim(StrSplit(inner, " + ", 2))
            
            if (p3 != "" and RegExMatch(p3, "^-?(0x)?[0-9a-fA-F]+$")) {
                val := p3
                op := "+"
                inner := Trim(StrSplit(inner, " + ", 1)) . " + " . Trim(StrSplit(inner, " + ", 2))
                has_disp := true
            } else if (p2 != "" and RegExMatch(p2, "^-?(0x)?[0-9a-fA-F]+$")) {
                val := p2
                op := "+"
                inner := Trim(StrSplit(inner, " + ", 1))
                has_disp := true
            }
            
            if (has_disp = false) {
                str m3 := Trim(StrSplit(inner, " - ", 3))
                str m2 := Trim(StrSplit(inner, " - ", 2))
                
                if (m3 != "" and RegExMatch(m3, "^-?(0x)?[0-9a-fA-F]+$")) {
                    val := m3
                    op := "-"
                    inner := Trim(StrSplit(inner, " - ", 1)) . " - " . Trim(StrSplit(inner, " - ", 2))
                    has_disp := true
                } else if (m2 != "" and RegExMatch(m2, "^-?(0x)?[0-9a-fA-F]+$")) {
                    val := m2
                    op := "-"
                    inner := Trim(StrSplit(inner, " - ", 1))
                    has_disp := true
                }
            }
        }
        
        if (has_disp) {
            disp := parse_number(val)
            if (op = "-") { disp := -disp }
            if (disp >= -128 and disp <= 127) { disp_size := 1 }
            else { disp_size := 4 }
        }

        bool b_is_none := false
        bool is_sib := InStr(inner, "*")

        int imm_size := 4
        if (is_pure_disp) {
            int64 orig_disp := disp

            if (reg_id = 0 and mem_is_imm = false and mnemonic = "mov") {
                if (dest_is_mem) { opcode := (op_size = 8) ? 0xA2 : 0xA3 } 
                else { opcode := (op_size = 8) ? 0xA0 : 0xA1 }
                
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                out_hex .= dec_to_hex_pair(opcode)
                Loop, 8 {
                    out_hex .= " " . dec_to_hex_pair((orig_disp >> ((A_Index)*8)) & 0xFF)
                }
            } else {
                if (reg_id >= 8) { REX += 0x04 }
                
                if (op_size = 8) { imm_size := 1 }
                else if (op_size = 16) { imm_size := 2 }
                if (opcode = 0x83) { imm_size := 1 }

                if (REX > 0x40 or force_rex) { inst_len += 1 }
                if (op_size = 16) { inst_len += 1 }
                if (mem_is_imm) { inst_len += imm_size }
                
                if (orig_disp >= 0) {
                    disp := orig_disp - (4194304 + current_address + inst_len)
                    modrm := 0x05 | ((reg_id & 7) << 3)
                    
                    if (REX > 0x40 or force_rex) {
                        if (has_high_byte) { return "NULL" }
                        out_hex .= dec_to_hex_pair(REX) . " "
                    }
                    if (has_0F) { out_hex .= "0f " }
                    out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
                } else {
                    modrm := 0x04 | ((reg_id & 7) << 3)
                    sib := 0x25
                    
                    if (REX > 0x40 or force_rex) {
                        if (has_high_byte) { return "NULL" }
                        out_hex .= dec_to_hex_pair(REX) . " "
                    }
                    if (has_0F) { out_hex .= "0f " }
                    out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm) . " " . dec_to_hex_pair(sib)
                }
                out_hex .= " " . dec_to_hex_pair(disp & 0xFF) . " " . dec_to_hex_pair((disp >> 8) & 0xFF) . " " . dec_to_hex_pair((disp >> 16) & 0xFF) . " " . dec_to_hex_pair((disp >> 24) & 0xFF)
            }
        }
        else if (is_sib) {
            str base_reg  := ""
            str index_reg := ""
            str scale_str := ""
            int b_id := 0
            int i_id := 0

            if (InStr(inner, "+")) {
                base_reg  := Trim(StrSplit(inner, "+", 1))
                str rest  := Trim(StrSplit(inner, "+", 2))
                index_reg := Trim(StrSplit(rest, "*", 1))
                scale_str := Trim(StrSplit(rest, "*", 2))
                b_id := get_reg_id(base_reg, registers)
                i_id := get_reg_id(index_reg, registers)
            } else {
                index_reg := Trim(StrSplit(inner, "*", 1))
                scale_str := Trim(StrSplit(inner, "*", 2))
                b_id := 5          
                disp_size := 4     
                b_is_none := true  
                i_id := get_reg_id(index_reg, registers)
            }

            if (scale_str != "1" and scale_str != "2" and scale_str != "4" and scale_str != "8") {
                return "NULL"
            }

            if (reg_id >= 8) { REX += 0x04 } 
            if (i_id >= 8)   { REX += 0x02 } 
            if (b_id >= 8 and b_is_none = false) { REX += 0x01 } 

            if (disp_size = 0) {
                if (b_id = 5 or b_id = 13) {
                    if (b_is_none = false) {
                        disp_size := 1
                        disp := 0
                    }
                }
            }

            uint64 mod_bits := 0x00
            if (disp_size = 1) { mod_bits := 0x40 }
            else if (disp_size = 4) { mod_bits := 0x80 }

            if (b_is_none) { mod_bits := 0x00 }

            modrm := mod_bits | ((reg_id & 7) << 3) | 0x04
            
            int ss := 0
            if (scale_str = "2") { ss := 1 }
            else if (scale_str = "4") { ss := 2 }
            else if (scale_str = "8") { ss := 3 }
            sib := (ss << 6) | ((i_id & 7) << 3) | (b_id & 7)
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            if (has_0F) { out_hex .= "0f " }
            out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm) . " " . dec_to_hex_pair(sib)
            
            if (disp_size = 1) {
                out_hex .= " " . dec_to_hex_pair(disp & 0xFF)
            } else if (disp_size = 4) {
                out_hex .= " " . dec_to_hex_pair(disp & 0xFF) . " " . dec_to_hex_pair((disp >> 8) & 0xFF) . " " . dec_to_hex_pair((disp >> 16) & 0xFF) . " " . dec_to_hex_pair((disp >> 24) & 0xFF)
            }
        }
        else {
            bool b_is_label := (inner != "rip" and get_reg_id(inner, registers) = -1)
            bool b_is_rip := (inner = "rip" or b_is_label)
            int b_id := 0
            
            if (b_is_rip) {
                b_id := 5       
                disp_size := 4  
                
                if (b_is_label) {
                    int64 label_addr := get_label_address(inner)
                    if (label_addr != -1) {
                        int inst_len := 6
                        if (REX > 0x40 or force_rex) { inst_len += 1 }
                        if (op_size = 16) { inst_len += 1 }
                        if (mem_is_imm) { inst_len += imm_size }
                        
                        int64 target_addr := label_addr
                        target_addr := target_addr + disp
                        disp := target_addr - (4194304 + current_address + inst_len)
                    } else {
                        int inst_len := 6
                        if (REX > 0x40 or force_rex) { inst_len += 1 }
                        if (op_size = 16) { inst_len += 1 }
                        if (mem_is_imm) { inst_len += imm_size }

                        int64 target_addr := parse_number(inner)
                        target_addr := target_addr + disp
                        disp := target_addr - (4194304 + current_address + inst_len)
                    }
                }
            } else {
                b_id := get_reg_id(inner, registers)
                if (b_id = -1) {
                    return "NULL"
                }
            }

            if (reg_id >= 8) { REX += 0x04 }
            if (b_id >= 8 and b_is_rip = false) { REX += 0x01 }

            if (disp_size = 0) {
                if (b_id = 5 or b_id = 13) {
                    if (b_is_rip = false) {
                        disp_size := 1
                        disp := 0
                    }
                }
            }

            uint64 mod_bits := 0x00
            if (disp_size = 1) { mod_bits := 0x40 }
            else if (disp_size = 4) { mod_bits := 0x80 }

            if (b_is_rip) { mod_bits := 0x00 }

            if (b_id = 4 or b_id = 12) and (b_is_rip = false) {
                modrm := mod_bits | ((reg_id & 7) << 3) | 0x04
                sib := 0x24
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                if (has_0F) { out_hex .= "0f " }
                out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm) . " " . dec_to_hex_pair(sib)
            } else {
                modrm := mod_bits | ((reg_id & 7) << 3) | (b_id & 7)
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                if (has_0F) { out_hex .= "0f " }
                out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
            }

            if (disp_size = 1) {
                out_hex .= " " . dec_to_hex_pair(disp & 0xFF)
            } else if (disp_size = 4) {
                out_hex .= " " . dec_to_hex_pair(disp & 0xFF) . " " . dec_to_hex_pair((disp >> 8) & 0xFF) . " " . dec_to_hex_pair((disp >> 16) & 0xFF) . " " . dec_to_hex_pair((disp >> 24) & 0xFF)
            }
        }

        if (mem_is_imm) {
            if (op_size = 8 or opcode = 0x83) {
                out_hex .= " " . dec_to_hex_pair(imm_val & 0xFF)
            } else if (op_size = 16) {
                out_hex .= " " . dec_to_hex_pair(imm_val & 0xFF) . " " . dec_to_hex_pair((imm_val >> 8) & 0xFF)
            } else {
                out_hex .= " " . dec_to_hex_pair(imm_val & 0xFF) . " " . dec_to_hex_pair((imm_val >> 8) & 0xFF) . " " . dec_to_hex_pair((imm_val >> 16) & 0xFF) . " " . dec_to_hex_pair((imm_val >> 24) & 0xFF)
            }
        }
    }
    else if (src_is_imm and is_shift_rotate = false) {
        int64 imm := 0
        str trim_src := Trim(src_op)
        if (RegExMatch(trim_src, "^'.*'$") > 0) {
            str char1 := StrReplace(trim_src, "'", "")
            imm := Asc(Trim(char1))
        } else {
            imm := parse_number(trim_src)
        }
        
        if (dest_reg_id >= 8) { REX += 0x01 }
        if (dest_reg_id >= 4 and dest_reg_id <= 7 and op_size = 8 and dest_has_high = false) { force_rex := true }

        if (mnemonic != "mov") {
            if (imm < -2147483648 or imm > 2147483647) {
                return "NULL"
            }
        }

        bool use_short_form := false
        if (op_size < 64) {
            use_short_form := true
        } else {
            if (imm < -2147483648 or imm > 2147483647) {
                use_short_form := true
            }
        }

        bool use_83 := false
        if (mnemonic != "mov" and mnemonic != "test" and mnemonic != "imul" and op_size > 8) {
            if (imm >= -128 and imm <= 127) {
                use_83 := true
            }
        }

        bool use_rax_shortcut := (dest_reg_id = 0) and (mnemonic != "mov") and (mnemonic != "imul") and (use_83 = false)

        if (use_rax_shortcut) {
            if (mnemonic = "test") {
                opcode := (op_size = 8) ? 0xA8 : 0xA9
            } else {
                int base_op := get_mnemonic_info(mnemonic, "base_op")
                opcode := (op_size = 8) ? (base_op + 4) : (base_op + 5)
            }
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            out_hex .= dec_to_hex_pair(opcode)
            
            if (op_size = 8) { out_hex .= " " . dec_to_hex_pair(imm & 0xFF) }
            else if (op_size = 16) { out_hex .= " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF) }
            else { out_hex .= " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF) . " " . dec_to_hex_pair((imm >> 16) & 0xFF) . " " . dec_to_hex_pair((imm >> 24) & 0xFF) }
        }
        else if (use_83) {
            opcode := 0x83
            modrm := 0xC0 | (get_mnemonic_info(mnemonic, "imm_ext") << 3) | (dest_reg_id & 7)
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm) . " " . dec_to_hex_pair(imm & 0xFF)
        }
        else if (use_short_form and mnemonic = "mov") {
            if (op_size = 8) {
                opcode := 0xB0 + (dest_reg_id & 7)
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(imm & 0xFF)
            } else if (op_size = 16) {
                opcode := 0xB8 + (dest_reg_id & 7)
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF)
            } else if (op_size = 32) {
                opcode := 0xB8 + (dest_reg_id & 7)
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF) . " " . dec_to_hex_pair((imm >> 16) & 0xFF) . " " . dec_to_hex_pair((imm >> 24) & 0xFF)
            } else {
                opcode := 0xB8 + (dest_reg_id & 7)
                if (REX > 0x40 or force_rex) {
                    if (has_high_byte) { return "NULL" }
                    out_hex .= dec_to_hex_pair(REX) . " "
                }
                out_hex .= dec_to_hex_pair(opcode)
                Loop, 8 {
                    out_hex .= " " . dec_to_hex_pair((imm >> ((A_Index)*8)) & 0xFF)
                }
            }
        } else {
            if (mnemonic = "mov") {
                opcode := 0xC7
                if (op_size = 8) { opcode := 0xC6 }
                modrm  := 0xC0 | (dest_reg_id & 7)
            } else if (mnemonic = "test") {
                opcode := (op_size = 8) ? 0xF6 : 0xF7
                modrm  := 0xC0 | (dest_reg_id & 7)
            } else if (mnemonic = "imul") {
                bool imm_fits_8 := (imm >= -128 and imm <= 127)
                opcode := imm_fits_8 ? 0x6B : 0x69
                modrm := 0xC0 | ((dest_reg_id & 7) << 3) | (dest_reg_id & 7)
            } else {
                opcode := (op_size = 8) ? 0x80 : 0x81
                modrm  := 0xC0 | (get_mnemonic_info(mnemonic, "imm_ext") << 3) | (dest_reg_id & 7)
            }
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
            
            if (op_size = 8 or opcode = 0x6B) {
                out_hex .= " " . dec_to_hex_pair(imm & 0xFF)
            } else if (op_size = 16) {
                out_hex .= " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF)
            } else {
                out_hex .= " " . dec_to_hex_pair(imm & 0xFF) . " " . dec_to_hex_pair((imm >> 8) & 0xFF) . " " . dec_to_hex_pair((imm >> 16) & 0xFF) . " " . dec_to_hex_pair((imm >> 24) & 0xFF)
            }
        }
    }
    else {
        if (dest_reg_id = -1) {
            return "NULL"
        }

        if (mnemonic = "push" or mnemonic = "pop") {
            if (op_size = 8 or op_size = 32) {
                return "NULL"
            }
            str prefix := ""
            if (op_size = 16) {
                prefix := "66 "
            }
            if (dest_reg_id >= 8) {
                prefix .= "41 "
            }
            int base := (mnemonic = "push") ? 0x50 : 0x58
            out_hex := prefix . dec_to_hex_pair(base + (dest_reg_id & 7))
            return out_hex
        }

        if (is_shift_rotate) {
            if (src_op = "1") {
                opcode := (op_size = 8) ? 0xD0 : 0xD1
            } else if (src_op = "cl") {
                opcode := (op_size = 8) ? 0xD2 : 0xD3
            } else if (src_is_imm) {
                opcode := (op_size = 8) ? 0xC0 : 0xC1
                imm_val := parse_number(src_op)
            } else {
                return "NULL"
            }
            
            if (dest_reg_id >= 8) { REX += 0x01 }
            modrm := 0xC0 | (ext << 3) | (dest_reg_id & 7)
            
            if (dest_reg_sz = 8 and dest_reg_id >= 4 and dest_reg_id <= 7 and dest_has_high = false) { force_rex := true }
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
            if (src_is_imm and src_op != "1") {
                out_hex .= " " . dec_to_hex_pair(imm_val & 0xFF)
            }
            return out_hex
        }

        if (src_op = "") {
            int ext_single := 0
            if (mnemonic = "inc") { ext_single := 0 }
            else if (mnemonic = "dec") { ext_single := 1 }
            else if (mnemonic = "call") { ext_single := 2 }
            else if (mnemonic = "not") { ext_single := 2 }
            else if (mnemonic = "neg") { ext_single := 3 }
            else if (mnemonic = "jmp") { ext_single := 4 }
            else if (mnemonic = "mul") { ext_single := 4 }
            else if (mnemonic = "imul") { ext_single := 5 }
            else if (mnemonic = "div") { ext_single := 6 }
            else if (mnemonic = "idiv") { ext_single := 7 }
            
            if (dest_reg_id >= 8) { REX += 0x01 }
            
            bool is_group3 := (mnemonic = "not" or mnemonic = "neg" or mnemonic = "mul" or mnemonic = "imul" or mnemonic = "div" or mnemonic = "idiv")
            if (mnemonic = "call" or mnemonic = "jmp") {
                opcode := 0xFF
            } else if (is_group3) {
                opcode := (op_size = 8) ? 0xF6 : 0xF7
            } else {
                opcode := (op_size = 8) ? 0xFE : 0xFF
            }
            
            modrm := 0xC0 | (ext_single << 3) | (dest_reg_id & 7)
            
            if (dest_reg_sz = 8 and dest_reg_id >= 4 and dest_reg_id <= 7 and dest_has_high = false) { force_rex := true }
            
            if (REX > 0x40 or force_rex) {
                if (has_high_byte) { return "NULL" }
                out_hex .= dec_to_hex_pair(REX) . " "
            }
            out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
            return out_hex
        }

        bool is_ext_instr := (mnemonic = "movzx" or mnemonic = "movsx" or mnemonic = "movsxd" or mnemonic = "imul")
        
        if (is_ext_instr) {
            if (dest_reg_id >= 8) { REX += 0x04 } 
            if (src_reg_id >= 8)  { REX += 0x01 } 
        } else {
            if (dest_reg_id >= 8) { REX += 0x01 } 
            if (src_reg_id >= 8)  { REX += 0x04 } 
        }
        
        if (op_size = 8) {
            if (dest_reg_id >= 4 and dest_reg_id <= 7 and dest_has_high = false) { force_rex := true }
            if (src_reg_id >= 4 and src_reg_id <= 7 and src_has_high = false) { force_rex := true }
        }
        
        if (mnemonic = "mov") {
            opcode := (op_size = 8) ? 0x88 : 0x89
        } else if (mnemonic = "movzx") {
            has_0F := true
            opcode := (src_reg_sz = 8) ? 0xB6 : 0xB7
        } else if (mnemonic = "movsx") {
            has_0F := true
            opcode := (src_reg_sz = 8) ? 0xBE : 0xBF
        } else if (mnemonic = "movsxd") {
            opcode := 0x63
        } else if (mnemonic = "test") {
            opcode := (op_size = 8) ? 0x84 : 0x85
        } else if (is_imul_3_op) {
            if (op_size = 8) { return "NULL" }
            int64 imul_imm_temp := parse_number(imul_imm_str)
            bool imm_fits_8 := (imul_imm_temp >= -128 and imul_imm_temp <= 127)
            opcode := imm_fits_8 ? 0x6B : 0x69
        } else if (mnemonic = "imul") {
            if (op_size = 8) { return "NULL" }
            has_0F := true
            opcode := 0xAF
        } else {
            int base_op := get_mnemonic_info(mnemonic, "base_op")
            opcode := (op_size = 8) ? (base_op + 2) : (base_op + 3)
        }
        
        is_ext_instr := (mnemonic = "movzx" or mnemonic = "movsx" or mnemonic = "movsxd" or mnemonic = "imul")
        bool uses_reg_rm_style := (is_ext_instr or (mnemonic != "mov"))
        
        if (uses_reg_rm_style) {
            modrm := 0xC0 | ((dest_reg_id & 7) << 3) | (src_reg_id & 7)
        } else {
            modrm := 0xC0 | ((src_reg_id & 7) << 3) | (dest_reg_id & 7)
        }
        
        if (REX > 0x40 or force_rex) {
            if (has_high_byte) { return "NULL" }
            out_hex .= dec_to_hex_pair(REX) . " "
        }
        if (has_0F) { out_hex .= "0f " }
        out_hex .= dec_to_hex_pair(opcode) . " " . dec_to_hex_pair(modrm)
    }

    if (is_imul_3_op) {
        int64 imul_imm := parse_number(imul_imm_str)
        bool imm_fits_8 := (imul_imm >= -128 and imul_imm <= 127)
        if (imm_fits_8) {
            out_hex .= " " . dec_to_hex_pair(imul_imm & 0xFF)
        } else {
            if (op_size = 16) {
                out_hex .= " " . dec_to_hex_pair(imul_imm & 0xFF) . " " . dec_to_hex_pair((imul_imm >> 8) & 0xFF)
            } else {
                out_hex .= " " . dec_to_hex_pair(imul_imm & 0xFF) . " " . dec_to_hex_pair((imul_imm >> 8) & 0xFF) . " " . dec_to_hex_pair((imul_imm >> 16) & 0xFF) . " " . dec_to_hex_pair((imul_imm >> 24) & 0xFF)
            }
        }
    }

    return out_hex
}









