    }
    
    tokens.add(" ")
    tokens.add(" ")

    token := ""
    str next_token := ""
    str next_location := ""
    str current_location := "" 
    int next_idx := 0
    str next2_token := ""
    int next2_idx := 0
    str next3_token := ""
    int next3_idx := 0
    str prev_token := ""
    bool add_space := true
    bool c_is_word := false
    bool n_is_word := false
    bool curr_is_obj := false
    bool prev_is_obj := false
    
                    str l1_line := ""
                int l1_col := 0
                
                str l2_line := ""
                int l2_col := 0
                
                    int expected_col := 0
    

    Loop, tokens.size() - 4 {
        if (skip > 0) {
            skip--
            continue
        }

        token := tokens[A_Index]
        current_location := locations[A_Index]
        
        next_token := ""
        next2_token := ""
        next3_token := ""
        prev_token := ""
        add_space := true
        c_is_word := false
        n_is_word := false
        curr_is_obj := false
        prev_is_obj := false
        next_location := ""  

        next_idx := A_Index + 1
        if (next_idx < tokens.size()) { 
            next_token := tokens[next_idx]
        }
        
        ; PROTECT LOCATIONS ARRAY FROM OUT-OF-BOUNDS CRASH
        if (next_idx < locations.size()) {
            next_location := locations[next_idx]
        } else {
            next_location := ""
        }

        next2_idx := A_Index + 2
        if (next2_idx < tokens.size()) { next2_token := tokens[next2_idx] }

        next3_idx := A_Index + 3
        if (next3_idx < tokens.size()) { next3_token := tokens[next3_idx] }


        if (A_Index > 1) { prev_token := tokens[A_Index - 1] }

        Loop, object_names.size() {
            if (token = object_names[A_Index]) {
                curr_is_obj := true
            }
            if (prev_token = object_names[A_Index]) {
                prev_is_obj := true
            }
        }

        if (token = ";") {
            out .= Chr(10)
        }
        else if (token = "{") {
            out .= Chr(10) . "{" . Chr(10)
        }
        else if (token = "}") {
            out .= Chr(10) . "}" . Chr(10)
        }
        else {
            if (RegExMatch(token, "^\w+$") > 0) { c_is_word := true }
            if (RegExMatch(next_token, "^\w+$") > 0) { n_is_word := true }

            if (next_token = "(") or (next_token = ")") or (next_token = "]") {
                add_space := false
            }
            else if (next_token = "[") {
                if (c_is_word = true) {
                    add_space := false
                } else {
                    add_space := true
                }
            }
            else if (token = "(") or (token = "[") {
                add_space := false
            }
            else if (next_token = ",") {
                add_space := false
            }
            else if (c_is_word = false) and (n_is_word = false) {
                add_space := false
            }


            if (next_token = "=") {
                add_space := true
            }
            if (token = "=") {
                add_space := true
            }



            if (token = keyWordEscape) {
                add_space := false
            }
            
            if (token = "!") or (next_token = ":") {
                add_space := false
            }
            
            if (token = ".") or (next_token = ".") {
                add_space := false
            }

            if (next_token = "-") or (next_token = "[") {
                add_space := true
            }



            if (token = "-") {
                l1_line := StrSplit(current_location, ":", 1)
                l1_col := INT(StrSplit(current_location, ":", 2))
                
                l2_line := StrSplit(next_location, ":", 1)
                l2_col := INT(StrSplit(next_location, ":", 2))
                
                if (l1_line = l2_line) {

                    expected_col := l1_col + StrLen(next_token)
                    if (expected_col = l2_col) {
                        add_space := false
                    } else {
                        add_space := true
                    }
                } else {
                    add_space := true
                }
            }

            if (token = "&") or (token = "|") {
                if (next_token = "(") {
                    add_space := true
                }
            }

            if (token = "$") {
                add_space := false
            }

            if (token = ",") {
                add_space := true
            }

            if (token = ")") or (token = "]") {
                add_space := true
                if (next_token = ")") or (next_token = "]") or (next_token = ",") or (next_token = ";") or (next_token = ".") or (next_token = ":") {
                    add_space := false
                }
            }

            if (add_space = true) {
                out .= token . " "
            } else {
                out .= token
            }
        }
    }

str out2 := ""
Loop, Parse, out, `n, `r {
    str line := A_LoopField
    str trimmed := Trim(line)
    
    if (SubStr(trimmed, 1, 4) = "jmp.") {
        line := StrReplace(line, "jmp.", "jmp .")  ; replace first occurrence only
    }
    else if (SubStr(trimmed, 1, 3) = "je.") {
        line := StrReplace(line, "je.", "je .")
    }
    else if (SubStr(trimmed, 1, 4) = "jne.") {
        line := StrReplace(line, "jne.", "jne .")
    }
    else if (SubStr(trimmed, 1, 3) = "jl.") {
        line := StrReplace(line, "jl.", "jl .")
    }
    else if (SubStr(trimmed, 1, 4) = "jle.") {
        line := StrReplace(line, "jle.", "jle .")
    }
    else if (SubStr(trimmed, 1, 3) = "jg.") {
        line := StrReplace(line, "jg.", "jg .")
    }
    else if (SubStr(trimmed, 1, 4) = "jge.") {
        line := StrReplace(line, "jge.", "jge .")
    }
    else if (SubStr(trimmed, 1, 3) = "ja.") {
        line := StrReplace(line, "ja.", "ja .")
    }
    else if (SubStr(trimmed, 1, 4) = "jae.") {
        line := StrReplace(line, "jae.", "jae .")
    }
    else if (SubStr(trimmed, 1, 3) = "jb.") {
        line := StrReplace(line, "jb.", "jb .")
    }
    else if (SubStr(trimmed, 1, 4) = "jbe.") {
        line := StrReplace(line, "jbe.", "jbe .")
    }
    else if (SubStr(trimmed, 1, 3) = "jc.") {
        line := StrReplace(line, "jc.", "jc .")
    }
    else if (SubStr(trimmed, 1, 4) = "jnc.") {
        line := StrReplace(line, "jnc.", "jnc .")
    }
    else if (SubStr(trimmed, 1, 3) = "jo.") {
        line := StrReplace(line, "jo.", "jo .")
    }
    else if (SubStr(trimmed, 1, 4) = "jno.") {
        line := StrReplace(line, "jno.", "jno .")
    }
    else if (SubStr(trimmed, 1, 3) = "js.") {
        line := StrReplace(line, "js.", "js .")
    }
    else if (SubStr(trimmed, 1, 4) = "jns.") {
        line := StrReplace(line, "jns.", "jns .")
    }
    else if (SubStr(trimmed, 1, 4) = "jpe.") {
        line := StrReplace(line, "jpe.", "jpe .")
    }
    else if (SubStr(trimmed, 1, 4) = "jpo.") {
        line := StrReplace(line, "jpo.", "jpo .")
    }
    else if (SubStr(trimmed, 1, 3) = "jz.") {
        line := StrReplace(line, "jz.", "jz .")
    }
    else if (SubStr(trimmed, 1, 4) = "jnz.") {
        line := StrReplace(line, "jnz.", "jnz .")
    }
    
    out2 .= line . Chr(10)
}

StringTrimRight, out, out2, 1  ; remove last newline
out := StrReplace(out, "''", "32")

;out := indent_nested_curly_braces(out)
out := restoreStrings_tundra(out)
;print("================== OUT ==================")
;print("================== OUT ==================")
;print("================== OUT ==================")
;print(out)
return out
}


; TUNDRA PARSER AND TOKENIZER
; TUNDRA PARSER AND TOKENIZER
; TUNDRA PARSER AND TOKENIZER
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;




str error_line := ""

func int assembler(str code, str file_name) {


    arr str allData
    arr str header

    str start1 := "00" ; Will be updated dynamically
    str start2 := "00" 
    str start3 := "00" 
    str start4 := "00" 

    code := Tundra_for_asm(code)
    ;print("========== in assembler ==========")
    HT_LIB_theIdNumOfThe34 := 0
    HT_Lib_theIdNumOfThe34theVar := []
    ; The ultimate 2-segment, 174-byte header template
    ; PHDR 1: Maps the ENTIRE file (Data + Code) at 0x400000
    ; PHDR 2: Maps the BSS variables at 0x10000000
    header := ["7f", "45", "4c", "46", "02", "01", "01", "03", "00", "00", "00", "00", "00", "00", "00", "00", "02", "00", "3e", "00", "01", "00", "00", "00", start1, start2, start3, start4, "00", "00", "00", "00", "40", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "40", "00", "38", "00", "02", "00", "40", "00", "00", "00", "00", "00", "01", "00", "00", "00", "07", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "40", "00", "00", "00", "00", "00", "00", "00", "40", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "10", "00", "00", "00", "00", "00", "00", "01", "00", "00", "00", "06", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "10", "00", "00", "00", "00", "00", "00", "00", "10", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "00", "10", "00", "00", "00", "00"]

    str temp_encode_out := ""
    str save_start_temp := ""
    
    arr str str_names
    arr int str_size
    arr str str_size_name
    arr str str_name_size_num
    arr str str_names_arrd
    uint64 mock_address_str := 0

    int str_names_size := 0
    
    arr str equ_names
    arr str equ_values

    ; Your exact original BSS logic
    uint64 current_bss_addr := 268435456
    int total_bss_size := 0

    str keyWordEscpaeChar := Chr(92)
    code := preserveStrings(code)
    str code_out := ""

    Loop, Parse, code, `n, `r {
        str trimmed_line := Trim(A_LoopField)

        if (InStr(trimmed_line, "format ") = 1) or (InStr(trimmed_line, "entry ") = 1) or (InStr(trimmed_line, "segment ") = 1) {
            continue
        }

if (InStr(A_LoopField, " db ")) {
            str_names_size := 0
            str1 := Trim(StrSplit(A_LoopField, " db ", 1))
            str2 := Trim(StrSplit(A_LoopField, " db ", 2))
            str3 := Trim(StrSplit(str2, ",", 1))
            str4 := Trim(StrSplit(str2, ",", 2))

            Loop, % HT_LIB_theIdNumOfThe34 {
                if (HT_LIB_theIdNumOfThe34 = A_Index + 1) {
                    str3 := StrReplace(str3, "VYIGUOYIYVIUCFCYIUCFCYIGCYGICFHYFHCTCFTFDFGYGFC" . Chr(65) . Chr(65) . STR(A_Index + 1) . Chr(65) . Chr(65), StrReplace(HT_Lib_theIdNumOfThe34theVar[A_Index + 1], keyWordEscpaeChar, "\") . Chr(34))
                } else {
                    str3 := StrReplace(str3, "VYIGUOYIYVIUCFCYIUCFCYIGCYGICFHYFHCTCFTFDFGYGFC" . Chr(65) . Chr(65) . STR(A_Index + 1) . Chr(65) . Chr(65), StrReplace(HT_Lib_theIdNumOfThe34theVar[A_Index + 1], keyWordEscpaeChar, "\"))
                }
            }
            
            bool is_string := false
            if (SubStr(str3, 1, 1) = Chr(34) or SubStr(str3, 1, 1) = "'") {
                is_string := true
                str3 := StringTrimLeft(str3, 1)
                str3 := StringTrimRight(str3, 1)
            }

            mock_address_str := header.size()
            save_start_temp := address_to_hexstr(4194304 + mock_address_str)

            str_names.add(str1)
            str_names_arrd.add(save_start_temp)

            if (Trim(str4) = "") {
                if (str3 != "") {
                    if (is_string = false) {
                        header.add(dec_to_hex_pair(parse_number(str3)))
                        str_names_size++
                    } else {
                        Loop, Parse, str3 {
                            header.add(char_to_hex(A_LoopField))
                            str_names_size++
                        }
                    }
                }
            } else {
                if (str3 = "") {
                    header.add(char_to_hex(Chr(parse_number(str4))))
                    str_names_size++
                } else {
                    if (is_string = false) {
                        header.add(dec_to_hex_pair(parse_number(str3)))
                        str_names_size++
                    } else {
                        Loop, Parse, str3 {
                            header.add(char_to_hex(A_LoopField))
                            str_names_size++
                        }
                    }
                    header.add(char_to_hex(Chr(parse_number(str4))))
                    str_names_size++
                }
            }

            str_size.add(str_names_size)
        }
        else if (InStr(A_LoopField, " dq ")) {
            str1 := Trim(StrSplit(A_LoopField, " dq ", 1)) 
            str2 := Trim(StrSplit(A_LoopField, " dq ", 2)) 
            
            mock_address_str := header.size()
            save_start_temp := address_to_hexstr(4194304 + mock_address_str)
            
            str_names.add(str1)
            str_names_arrd.add(save_start_temp)
            
            str dq_hex := size_to_hex64(parse_number(str2))
            Loop, Parse, dq_hex, " " {
                header.add(A_LoopField)
            }
            

            str_size.add(8)
        }
        else if (InStr(A_LoopField, " rb ")) {
            str1 := Trim(StrSplit(A_LoopField, " rb ", 1)) 
            str2 := Trim(StrSplit(A_LoopField, " rb ", 2)) 
            
            str_names.add(str1)
            str_names_arrd.add(address_to_hexstr(current_bss_addr))
            ; FIXED: Keep the str_size array synchronized
            str_size.add(INT(str2))
            current_bss_addr := current_bss_addr + INT(str2)
            total_bss_size := total_bss_size + INT(str2)
        }
        else if (InStr(A_LoopField, " rq ")) {
            str1 := Trim(StrSplit(A_LoopField, " rq ", 1)) 
            str2 := Trim(StrSplit(A_LoopField, " rq ", 2)) 
            
            str_names.add(str1)
            str_names_arrd.add(address_to_hexstr(current_bss_addr))
            
            int reserved_bytes := INT(str2) * 8
            ; FIXED: Keep the str_size array synchronized
            str_size.add(reserved_bytes)
            current_bss_addr := current_bss_addr + reserved_bytes
            total_bss_size := total_bss_size + reserved_bytes
        }
        else if (InStr(A_LoopField, "=") and InStr(A_LoopField, "$-") = 0) {
            str1 := Trim(StrSplit(A_LoopField, "=", 1))
            str2 := Trim(StrSplit(A_LoopField, "=", 2))
            equ_names.add(str1)
            equ_values.add(str2)
        }
        else if (InStr(A_LoopField, " = $-")) or (InStr(A_LoopField, "= $-")) or (InStr(A_LoopField, " =$-")) or (InStr(A_LoopField, "=$-")) {
            if (InStr(A_LoopField, " = $-")) {
                str1 := Trim(StrSplit(A_LoopField, " = $-", 1))
                str2 := Trim(StrSplit(A_LoopField, " = $-", 2))
            } else if (InStr(A_LoopField, "= $-")) {
                str1 := Trim(StrSplit(A_LoopField, "= $-", 1))
                str2 := Trim(StrSplit(A_LoopField, "= $-", 2))
            } else if (InStr(A_LoopField, " =$-")) {
                str1 := Trim(StrSplit(A_LoopField, " =$-", 1))
                str2 := Trim(StrSplit(A_LoopField, " =$-", 2))
            } else if (InStr(A_LoopField, "=$-")) {
                str1 := Trim(StrSplit(A_LoopField, "=$-", 1))
                str2 := Trim(StrSplit(A_LoopField, "=$-", 2))
            }
            str_size_name.add(str1)
            Loop, str_names.size() {
                if (str2 = str_names[A_Index]) {
                    str_name_size_num.add(STR(str_size[A_Index]))
                    break
                }
            }
        }
        else {
            code_out .= A_LoopField . Chr(10)
        }
    }
    
    code := Trim(code_out)

    Loop, str_names.size() {
        code := RegExReplace(code, "\b" . str_names[A_Index] . "\b", str_names_arrd[A_Index])
    }

    Loop, str_size_name.size() {
        code := RegExReplace(code, "\b" . str_size_name[A_Index] . "\b", str_name_size_num[A_Index])
    }

    Loop, equ_names.size() {
        str safe_name := StrReplace(equ_names[A_Index], ".", "\.")
        code := RegExReplace(code, "\b" . safe_name . "\b", equ_values[A_Index])
    }

    set_first_pass(true)
    uint64 mock_address := header.size()

    Loop, Parse, code, `n, `r {
        str line := Trim(A_LoopField)
        if (line = "") { continue }

        if (RegExMatch(line, "^\s*([a-zA-Z._][a-zA-Z0-9$_.]*):")) {
            str label_name := StrReplace(line, ":", "")
             
            if (line = "_start:") {
                save_start_temp := size_to_hex64(4194304 + mock_address)
                Loop, Parse, save_start_temp, " " {
                    if (A_Index = 0) { header[24] := A_LoopField }
                    else if (A_Index = 1) { header[25] := A_LoopField }
                    else if (A_Index = 2) { header[26] := A_LoopField }
                    else if (A_Index = 3) { header[27] := A_LoopField }
                }
            } else {
                add_label(label_name, 4194304 + mock_address)
            }
        } else {
            set_current_address(mock_address)
            temp_encode_out := encode(line)
            int bc := get_byte_count(temp_encode_out)
            mock_address := mock_address + bc
        }
    }

    set_first_pass(false)

    Loop, Parse, code, `n, `r {
        str line := Trim(A_LoopField)
        if (line = "") { continue }

        if (RegExMatch(line, "^\s*([a-zA-Z._][a-zA-Z0-9$_.]*):")) {
            continue 
        } else {
            set_current_address(header.size())
            temp_encode_out := encode(line)

            if (temp_encode_out = "NULL") {
                error_line := line
                return 1
            }

            Loop, Parse, temp_encode_out, " " {
                if (Trim(A_LoopField) != "") {
                    header.add(Trim(A_LoopField))
                }
            }
        }
    }

    ; --- THE FINAL HEADER SIZE WRITES ---
    ; Segment 1 (File Data + Code)
    arr str file_size_hex := size_to_hex32(header.size())
    header[96]  := file_size_hex[0]
    header[97]  := file_size_hex[1]
    header[98]  := file_size_hex[2]
    header[99]  := file_size_hex[3]

    header[104] := file_size_hex[0]
    header[105] := file_size_hex[1]
    header[106] := file_size_hex[2]
    header[107] := file_size_hex[3]

    ; Segment 2 (BSS)
    if (total_bss_size > 0) {
        arr str bss_size_hex := size_to_hex32(total_bss_size)
        header[160] := bss_size_hex[0]
        header[161] := bss_size_hex[1]
        header[162] := bss_size_hex[2]
        header[163] := bss_size_hex[3]
    }

    final_assemble(file_name, header)
    print("HTLL-Assembler: Success")
    return 0
}

