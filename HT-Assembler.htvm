func str remove_comments(str code, str sl_mark, str ml_start, str ml_end, str escape_char) {
    
    str new_code := ""
    int code_len := 0
    int i_pos := 0
    str c := ""
    int skip := 0
    bool in_str := false
    bool in_slc := false
    bool in_mlc := false
    bool is_escaped := false
    int sl_len := 0
    int mls_len := 0
    int mle_len := 0
    str p_char := ""
    bool can_start_comment := false

    code_len := StrLen(code)
    sl_len := StrLen(sl_mark)
    mls_len := StrLen(ml_start)
    mle_len := StrLen(ml_end)

    Loop, code_len {
        if (skip > 0) {
            skip--
            continue
        }

        i_pos := A_Index + 1
        c := SubStr(code, i_pos, 1)

        if (c = Chr(10)) {
            in_slc := false
            is_escaped := false
            new_code .= c
            continue
        }

        if (in_slc = true) {
            continue
        }

        if (in_mlc = true) {
            if (mle_len > 0) {
                if (SubStr(code, i_pos, mle_len) = ml_end) {
                    in_mlc := false
                    skip := mle_len - 1
                }
            }
            continue
        }

        if (is_escaped = true) {
            is_escaped := false
            new_code .= c
            continue
        }

        if (in_str = true) {
            if (c = escape_char) {
                is_escaped := true
            } else if (c = Chr(34)) {
                in_str := false
            }
            new_code .= c
            continue
        }

        if (c = Chr(34)) {
            in_str := true
            new_code .= c
            continue
        }

        ; --- THE FIX: Only start SL comment if preceded by whitespace or Start-of-Line ---
        if (sl_len > 0) {
            if (SubStr(code, i_pos, sl_len) = sl_mark) {
                can_start_comment := false
                if (i_pos = 1) {
                    can_start_comment := true
                } else {
                    p_char := SubStr(code, i_pos - 1, 1)
                    if (p_char = " ") or (p_char = Chr(9)) or (p_char = Chr(10)) or (p_char = Chr(13)) {
                        can_start_comment := true
                    }
                }

                if (can_start_comment = true) {
                    in_slc := true
                    skip := sl_len - 1
                    continue
                }
            }
        }

        if (mls_len > 0) {
            if (SubStr(code, i_pos, mls_len) = ml_start) {
                in_mlc := true
                skip := mls_len - 1
                continue
            }
        }

        new_code .= c
    }
    return new_code
}

func str restoreStrings_tundra(str code) {
Loop, strings_count {

code := StrReplace(code, "vsiauydvgbausvbausodyfhidoufcgsiyouysfivgidfvasdkubfcasAA" . STR(A_Index + 1) . "AA", strings[A_Index])
}

return code
}

func bool tokenize_first_help(str c1, str c2) {
    if (RegExMatch(c1, "^\w$")) and (RegExMatch(c2, "^\w$")) {
        return false
    }
    return true
}

func void tokenize_first(str code) {

    arr str future
    str hold_temp := ""
    str hold_temp_strings := ""
    int inChr34 := 0
    int wasChr34 := 0
    int countNewLines := 0
    int countChars_num_on_same_line := 1
    bool is_escaped := false
    
    Loop, Parse, code {
        future.add(A_LoopField)
    }
    future.add(" ")
    
    Loop, Parse, code {
        if (A_LoopField = Chr(10)) {
            countNewLines++
            countChars_num_on_same_line := 0
        }
        else {
            countChars_num_on_same_line++
        }
        
        hold_temp .= A_LoopField
        if (tokenize_first_help(A_LoopField, future[A_Index + 1])) {


            if (is_escaped = true) {
                is_escaped := false
            } else if (A_LoopField = keyWordEscape) {

                is_escaped := true
            } else if (A_LoopField = Chr(34)) {

                inChr34++
                wasChr34 := 1
            }
                
            if (inChr34 = 2) {
                hold_temp_strings .= hold_temp
                inChr34 := 0
                wasChr34 := 0
                strings_count++
                strings.add(hold_temp_strings)
                tokens.add("vsiauydvgbausvbausodyfhidoufcgsiyouysfivgidfvasdkubfcasAA" . STR(strings_count) . "AA")
                hold_temp_strings := ""
                locations.add(STR(countNewLines + 1) . ":" . STR(countChars_num_on_same_line))
            }
            else {
                if (wasChr34 = 0) {
                    if (Trim(hold_temp) != "") {
                        tokens.add(hold_temp)
                        locations.add(STR(countNewLines + 1) . ":" . STR(countChars_num_on_same_line))
                    }
                }
                else {
                    hold_temp_strings .= hold_temp
                }
            }
            
            hold_temp := ""
        }
    }
}



func void tokenize_add_semicolons() {

    arr str new_tokens
    arr str new_locations
    int paren_depth := 0
    int bracket_depth := 0
    bool should_insert_semicolon := false
    str current_token := ""
    str next_token := ""
    str current_location := ""
    str next_location := ""
    str current_line_num := ""
    str next_line_num := ""
    bool is_on_new_line := false
    int loop_iterations := 0
    int original_tokens_initial_size := 0
    int new_tokens_final_size := 0
    int next_idx := 0
    int nt_size := 0
    int last_idx := 0
    bool is_paren_brace_combo := false

    loop_iterations := tokens.size()

    Loop, loop_iterations {
        current_token := tokens[A_Index]
        current_location := locations[A_Index]

        next_idx := A_Index + 1
        if (next_idx < loop_iterations) {
            next_token := tokens[next_idx]
            next_location := locations[next_idx]
        } else {
            next_token := "SENTINEL_END_OF_INPUT"
            next_location := current_location
        }

        new_tokens.add(current_token)
        new_locations.add(current_location)

        if (current_token = "(") {
            paren_depth++
        } else if (current_token = ")") {
            paren_depth--
        } else if (current_token = "[") {
            bracket_depth++
        } else if (current_token = "]") {
            bracket_depth--
        }

        should_insert_semicolon := false
        is_on_new_line := false
        is_paren_brace_combo := false
        
        if (next_token != "SENTINEL_END_OF_INPUT") {
            current_line_num := StrSplit(current_location, ":", 1)
            next_line_num := StrSplit(next_location, ":", 1)
            if (current_line_num != next_line_num) {
                is_on_new_line := true
            }
        }

        if (current_token = ")") and (next_token = "{") {
            is_paren_brace_combo := true
        }

        if (paren_depth = 0) and (bracket_depth = 0) {
            if (current_token != ";") and (current_token != "{") and (current_token != "}") {
                if (is_on_new_line = true) {
                    if (current_token != "else") and (is_paren_brace_combo = false) and (next_token != "{") and (next_token != "else") and (next_token != "SENTINEL_END_OF_INPUT") {
                        should_insert_semicolon := true
                    }
                }
            }
            
            if (next_token = "}") and (is_on_new_line = true) and (current_token != "{") and (current_token != ";") {
                should_insert_semicolon := true
            }
        }
        
        if (should_insert_semicolon = true) {
            nt_size := new_tokens.size()
            if (nt_size > 0) {
                last_idx := nt_size - 1
                if (new_tokens[last_idx] = ";") {
                    should_insert_semicolon := false
                }
            }
        }

        if (should_insert_semicolon = true) {
            new_tokens.add(";")
            new_locations.add(current_location)
        }
    }

    original_tokens_initial_size := tokens.size()
    Loop, original_tokens_initial_size {
        tokens.pop()
        locations.pop()
    }

    new_tokens_final_size := new_tokens.size()
    Loop, new_tokens_final_size {
        tokens.add(new_tokens[A_Index])
        locations.add(new_locations[A_Index])
    }

    tokens.add(" ")
    tokens.add(" ")
}

func str getLastWordFromToken(str token) {
    str out := ""

    if (Trim(token) = "") {
        return Trim(token)
    }

    Loop, Parse, token, " " {
        out := Trim(A_LoopField)
    }
    return out
}

func str mask_arradd(str code) {


    str new_code := ""
    int code_len := 0
    int i := 1
    str c := ""
    int skip := 0
    int start_pos := 0
    str block_content := ""
    str rest_of_code := ""
    int found_in_rest := 0
    bool in_str := false
    bool is_escaped := false
    bool can_start := false
    str p_char := ""

    code_len := StrLen(code)

    Loop, code_len {
        if (skip > 0) {
            skip--
            continue
        }

        i := A_Index + 1
        c := SubStr(code, i, 1)

        ; --- String Protection ---
        if (is_escaped = true) {
            is_escaped := false
            new_code .= c
            continue
        }
        if (in_str = true) {
            if (c = keyWordEscape) {
                is_escaped := true
            } else if (c = Chr(34)) {
                in_str := false
            }
            new_code .= c
            continue
        }
        if (c = Chr(34)) {
            in_str := true
            new_code .= c
            continue
        }

        ; --- Detect arradd ---
        if (StrLower(c) = "a") {
            ; Check if it is "arradd" followed by a space or a tab
            if (StrLower(SubStr(code, i, 7)) = "arradd ") or (StrLower(SubStr(code, i, 7)) = "arradd" . Chr(9)) {
                
                ; Only trigger if it is at the start of a line or separated by whitespace
                can_start := false
                if (i = 1) {
                    can_start := true
                } else {
                    p_char := SubStr(code, i - 1, 1)
                    if (p_char = " ") or (p_char = Chr(9)) or (p_char = Chr(10)) or (p_char = Chr(13)) {
                        can_start := true
                    }
                }

                if (can_start = true) {
                    start_pos := i
                    
                    ; Look ahead for the line break
                    rest_of_code := SubStr(code, start_pos)
                    found_in_rest := InStr(rest_of_code, Chr(10))
                    
                    if (found_in_rest > 0) {
                        ; Grab everything up to the newline, but DO NOT include the Chr(10)
                        block_content := SubStr(code, start_pos, found_in_rest - 1)
                    } else {
                        ; If there is no newline, it goes to the end of the file
                        block_content := rest_of_code
                    }
                    
                    ; Strip trailing carriage return Chr(13) if Windows-style line endings \r\n
                    if (SubStr(block_content, StrLen(block_content), 1) = Chr(13)) {
                        block_content := SubStr(block_content, 1, StrLen(block_content) - 1)
                    }
                    
                    arradds_count++
                    arradds.add(block_content)
                    
                    ; Swap out with a unique token that passes the tokenizers "^\w+$" regex
                    new_code .= "vgdskjbhfgkjbfsgkjbdfsgjksdfgARRADD" . STR(arradds_count) . "AA"
                    
                    skip := StrLen(block_content) - 1
                    continue
                }
            }
        }

        new_code .= c
    }
    return new_code
}


